# Gemini LLM (required)
GEMINI_API_KEY=your_gemini_key_here

# Optional: override default LLM model
# LLM_MODEL_NAME=gemini-3.1-flash-lite-preview

# Sarvam AI Speech-to-Text (required)
SARVAMAI_API_KEY=your_sarvam_key_here

# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:5432/dbname
# Append ?sslmode=require for cloud-hosted databases (RDS, Cloud SQL, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/your_db
